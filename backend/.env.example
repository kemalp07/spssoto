# Karar katmanı — Claude Haiku (türev onayı, hipotez eşleşmesi, plan değerlendirmesi)
ANTHROPIC_API_KEY=sk-ant-buraya-key-gelecek
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Veri analisti katmanı — Gemini (tüm değişkenleri birlikte analiz eder)
# Google AI Studio anahtari: AIza... veya yeni nesil AQ...
GEMINI_API_KEY=
GEMINI_USE_VERTEX=false
GEMINI_MODEL=gemini-2.5-flash
ENABLE_GEMINI_ENRICH=true
# Gemini JSON/metin çıktı üst sınırı (varsayılan: model max)
# GEMINI_MAX_OUTPUT_TOKENS=65536
# Yalnizca Google Cloud Vertex (servis hesabi) icin:
# GEMINI_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# İsteğe bağlı override; tanımlı değilse ANTHROPIC_MODEL kullanılır
# CUTOFF_MODEL=claude-haiku-4-5-20251001
# BULGU_MODEL=claude-haiku-4-5-20251001
# CORS — virgülle ayrılmış origin listesi (tanımsızsa http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
